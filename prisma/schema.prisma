// JobBlast data model — see PRD §7
// Single-user tool for v1: one User row, seeded from the connected resume.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  // Master resume in a structured-ish text form. Tailoring reworks bullets from this.
  masterResume      String
  // JSON: array of { name, tone, body } cover-letter templates.
  coverTemplates    String   @default("[]")
  // JSON string arrays of the user's targeting preferences.
  targetRoles       String   @default("[]")
  targetLocations   String   @default("[]")
  salaryFloor       Int?
  excludedCompanies String   @default("[]")
  dailyGoal         Int      @default(50)
  // When true, scoring/filtering favors roles likely to offer visa sponsorship.
  sponsorshipRequired Boolean @default(false)
  createdAt         DateTime @default(now())

  applications Application[]
  matches      Match[]
}

model JobListing {
  id           String   @id @default(cuid())
  source       String // e.g. "mcp:ziprecruiter", "mcp:indeed", "adzuna"
  sourceJobId  String? // native id from the source, if any
  title        String
  company      String
  location     String
  isRemote     Boolean  @default(false)
  url          String // apply / redirect URL (Approve & Open target)
  description  String   @default("")
  salaryMin    Int?
  salaryMax    Int?
  jobType      String? // "fulltime", "contract", ...
  seniority    String? // inferred: intern|junior|mid|senior|lead
  country      String? // e.g. "IE", "US"
  // Visa-sponsorship signal: stated | likely | confirm | unknown (see detectSponsorship).
  sponsorship  String   @default("unknown")
  sponsorshipNote String @default("")
  postedDate   DateTime?
  fetchedAt    DateTime @default(now())
  // Fuzzy key (normalized company+title) for duplicate detection.
  dedupKey     String   @default("")

  applications Application[]
  matches      Match[]

  @@index([dedupKey])
  @@index([fetchedAt])
}

model Application {
  id             String   @id @default(cuid())
  userId         String
  jobListingId   String
  // queued -> approved -> applied -> responded -> interview -> rejected|offer
  status         String   @default("queued")
  // Snapshot of the exact documents used at Approve & Open time.
  resumeVersion  String?
  coverVersion   String?
  notes          String   @default("")
  appliedAt      DateTime?
  followUpDate   DateTime?
  createdAt      DateTime @default(now())
  lastUpdated    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  jobListing JobListing @relation(fields: [jobListingId], references: [id])

  @@unique([userId, jobListingId])
  @@index([status])
}

model Match {
  id             String   @id @default(cuid())
  userId         String
  jobListingId   String
  relevanceScore Int // 0-100
  // JSON array of human-readable reasons for the score.
  reasons        String   @default("[]")
  createdAt      DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  jobListing JobListing @relation(fields: [jobListingId], references: [id])

  @@unique([userId, jobListingId])
  @@index([relevanceScore])
}
